# Source and tests (dist/ is what ships)
src/
tests/
scripts/build-bundles.ts
playground/

# Build artifacts not needed at runtime
dist/bundles/
dist/*.tar.gz

# Dev tooling config (consumers don't need these)
biome.json
tsconfig.json
vitest.config.ts

# Git hooks
.husky/

# CI workflows (but NOT .github/agents/ or .github/instructions/ — those get installed)
.github/workflows/

# Skills are NOT shipped in the npm package — they are pulled fresh via `npx skills`
# (our 9 from kylebrodeur/wordpress-agent-kit, 17 upstream from WordPress/agent-skills).
# skills/ is the marketplace source committed to git; .agents/skills/ is dev-generated.
skills/
.agents/skills/

# Internal docs
CLI_REVIEW.md
CHANGELOG.md
RELEASE_NOTES.md

# Personal / machine-specific
.pi/
.vscode/
.gitignore

# Dependency artifacts
vendor/
coverage/
node_modules/
pnpm-lock.yaml
package-lock.json
