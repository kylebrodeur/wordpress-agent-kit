{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"include": ["src/**", "tests/**", "scripts/**", "extensions/**", "*.json", "*.mjs"],
		"ignore": [
			"**/dist/**",
			"**/node_modules/**",
			"**/coverage/**",
			"**/.agents/**",
			"**/skills/**",
			"**/vendor/**",
			".wp-agent-kit-manifest.*.json"
		],
		"ignoreUnknown": true
	},
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noExplicitAny": "warn"
			},
			"correctness": {
				"noUnusedVariables": "error"
			},
			"complexity": {
				"noUselessTernary": "error"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "es5",
			"semicolons": "always"
		}
	}
}
